{
  "name": "@forsakringskassan/semantic-release-monorepo",
  "version": "3.10.8",
  "private": true,
  "keywords": [
    "semantic-release"
  ],
  "homepage": "https://github.com/Forsakringskassan/semantic-release-config",
  "bugs": "https://github.com/Forsakringskassan/semantic-release-config/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/semantic-release-config.git"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "eslint": "eslint --cache .",
    "eslint:fix": "eslint --cache --fix .",
    "lerna": "lerna",
    "prepare": "commitlint-config",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "pretest": "npm run eslint && npm run prettier:check",
    "test": "node --experimental-vm-modules --test preset-utils.test.mjs",
    "posttest": "node scripts/dry-run.js"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "devDependencies": {
    "@forsakringskassan/commitlint-config": "4.1.2",
    "@forsakringskassan/eslint-config": "15.1.4",
    "@forsakringskassan/eslint-config-cli": "15.1.1",
    "@forsakringskassan/eslint-config-typescript": "15.1.2",
    "@forsakringskassan/prettier-config": "3.7.2",
    "@html-validate/release-scripts": "7.3.1",
    "@types/node": "22.20.0",
    "lerna": "9.0.7",
    "memfs": "4.57.8",
    "npm-pkg-lint": "5.1.8",
    "rimraf": "6.1.3"
  },
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >= 26.0.0"
  },
  "allowScripts": {
    "esbuild": true,
    "nx": false,
    "unrs-resolver": true
  }
}
