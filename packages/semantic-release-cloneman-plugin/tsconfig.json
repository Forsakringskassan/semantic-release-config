{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "declaration": true,
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "types": ["node"],
        "allowImportingTsExtensions": true
    },
    "include": ["src/**/*.ts"]
}
